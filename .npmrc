# Required for Expo + pnpm.
# - shamefully-hoist makes the node_modules layout flat enough that Expo's
#   autolinker and Metro's resolver can find native modules.
# - node-linker=hoisted is the pnpm equivalent of flat npm/yarn layouts.
# Without these, Metro fails with "Unable to resolve module" on native deps.
node-linker=hoisted
shamefully-hoist=true
public-hoist-pattern[]=*

# Exclude React from the hoist — web (React 19) and mobile (React 18) need
# separate copies. Without these exclusions, the mobile workspace resolves
# @types/react@19 and TS2786 errors fire across every JSX file.
public-hoist-pattern[]=!react
public-hoist-pattern[]=!react-dom
public-hoist-pattern[]=!@types/react
public-hoist-pattern[]=!@types/react-dom
