# ─────────────────────────────────────────────────────────────────────────────
# MLabs Template — environment variables
#
# Copy this file to `.env.local` for local dev. Each variable below documents:
#   • What it's for
#   • Where to obtain the value
#   • What breaks if it's missing
#
# Boot-time validation lives in src/config/env.ts. The app refuses to start
# if a required variable is missing or malformed.
# ─────────────────────────────────────────────────────────────────────────────

# Node runtime mode (development | test | production). Next.js sets this for you;
# only override in CI or special test runs.
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Database (Neon Postgres)
# Get from: https://console.neon.tech → Project → Connection Details
# Format:   postgres://user:pass@host/db?sslmode=require
# Without it: every DB query 500s; the app starts but is broken.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Better Auth — added in W2
# BETTER_AUTH_SECRET: random 32+ char string. Generate: openssl rand -base64 32
# BETTER_AUTH_URL:    public URL where the app is reachable (used for callbacks)
# Without these: auth flows break (logins, signups, password resets all fail).
# ─────────────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Postmark transactional email — added in W3
# Get from: https://account.postmarkapp.com/servers → your server → API Tokens
# POSTMARK_FROM_EMAIL must be a verified Sender Signature in your Postmark account
# Without these: email-dependent flows (verify email, password reset) fail.
# ─────────────────────────────────────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Replit Object Storage — added in W4
# Get from: Replit project → Tools → Object Storage → create bucket → copy ID
# Without it: file uploads (avatars etc.) fail.
# ─────────────────────────────────────────────────────────────────────────────
REPLIT_OBJECT_STORAGE_BUCKET_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Replit dev domain — injected automatically by Replit
# Get from: Replit injects it on workspace start; locally it's just unset.
# Used as a fallback when BETTER_AUTH_URL is unset (so BetterAuth cookies sign
# under the right baseUrl on the Replit preview) and to populate
# trustedOrigins in the CORS middleware for cross-port Expo web dev.
# Without it on Replit: BetterAuth issues cookies under localhost, the preview
# rejects them, sign-in silently fails.
# ─────────────────────────────────────────────────────────────────────────────
REPLIT_DEV_DOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — added in template hardening (2026-05-23)
# Get from: https://dashboard.stripe.com → Developers → API keys
# STRIPE_SECRET_KEY:     server secret (sk_test_... or sk_live_...)
# STRIPE_WEBHOOK_SECRET: signing secret for /api/stripe/webhook, returned by
#                       Stripe at endpoint-create time (whsec_...). Use
#                       `pnpm stripe:webhook-setup` (forks add when they need it)
#                       to provision the endpoint and capture the secret.
# Without these: Stripe-dependent flows (checkout, payments, webhooks) fail.
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Build-time escape hatch
# Set to 1 to skip env validation (e.g. for `next build` in CI without secrets).
# Use sparingly; bypassing validation hides real config errors.
# ─────────────────────────────────────────────────────────────────────────────
# SKIP_ENV_VALIDATION=1
