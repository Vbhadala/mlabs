{
  "name": "mlabs-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "pnpm --filter @mlabs/db generate",
    "db:migrate": "pnpm --filter @mlabs/db migrate",
    "db:studio": "pnpm --filter @mlabs/db studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "verify:deeplinks": "tsx scripts/verify-deeplinks.ts",
    "check-contrast": "tsx scripts/check-contrast.ts",
    "gen:mobile-tw": "tsx scripts/gen-mobile-tailwind.ts",
    "gen:mobile-tw:check": "tsx scripts/gen-mobile-tailwind.ts --check"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@mlabs/auth": "workspace:*",
    "@mlabs/config": "workspace:*",
    "@mlabs/db": "workspace:*",
    "@mlabs/email": "workspace:*",
    "@mlabs/ui-web": "workspace:*",
    "@mlabs/validators": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@replit/object-storage": "^1.0.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "postmark": "^4.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "@mlabs/eslint-config": "workspace:*",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "turbo": "^2.5.10",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}
